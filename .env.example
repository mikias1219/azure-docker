# ============================================================
# Azure Practice App — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
#
# Provisioning: run scripts/create_all_azure_services.sh (after az login)
# to create all Azure resources. See docs/AZURE_SERVICES.md for how each
# service is built and provisioned for its purpose.
# ============================================================

# ── App Security ─────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production

# ── Database ──────────────────────────────────────────────────
# SQLite for local dev; use a persistent path in ACI
DATABASE_URL=sqlite:///./app.db
UPLOADS_DIR=uploads

# ── Azure Document Intelligence (Form Recognizer) ────────────
AZURE_FORM_RECOGNIZER_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_FORM_RECOGNIZER_KEY=your-form-recognizer-key-here

# ── Azure AI Language (Text Analytics, QnA, CLU/Clock) ───────
AZURE_LANGUAGE_ENDPOINT=https://<your-language-resource>.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=your-language-key-here

# ── Azure QnA (Question Answering) ───────────────────────────
AZURE_QNA_PROJECT_NAME=LearnFAQ
AZURE_QNA_DEPLOYMENT_NAME=production

# ── Azure OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
OPENAI_API_BASE=https://<your-openai-resource>.openai.azure.com/
OPENAI_DEPLOYMENT_NAME=gpt-35-turbo
OPENAI_API_VERSION=2024-02-15-preview
# Embedding model for RAG pipeline
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002

# ── Azure AI Vision ───────────────────────────────────────────
AZURE_AI_VISION_ENDPOINT=https://<your-vision-resource>.cognitiveservices.azure.com/
AZURE_AI_VISION_KEY=your-vision-key-here

# ── Azure AI Search (Knowledge Mining + RAG) ──────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_KEY=your-search-key-here
AZURE_SEARCH_INDEX_NAME=rag-content-index

# ── Optional: Azure Speech (transcription, future use) ────────
# AZURE_SPEECH_KEY=your-speech-key-here
# AZURE_SPEECH_REGION=eastus
