{
  "location": "eastus",
  "properties": {
    "imageRegistryCredentials": [
      {
        "server": "selamnew.azurecr.io",
        "username": "__ACR_USERNAME__",
        "password": "__ACR_PASSWORD__"
      }
    ],
    "containers": [
      {
        "name": "document-intelligence-app",
        "properties": {
          "image": "__IMAGE__",
          "resources": {
            "requests": {
              "cpu": 1,
              "memoryInGb": 2
            }
          },
          "ports": [
            {
              "port": 80
            }
          ],
          "environmentVariables": [
            {
              "name": "DATABASE_URL",
              "value": "sqlite:///./app.db"
            },
            {
              "name": "AZURE_FORM_RECOGNIZER_ENDPOINT",
              "value": "__AZURE_FORM_RECOGNIZER_ENDPOINT__"
            },
            {
              "name": "AZURE_FORM_RECOGNIZER_KEY",
              "value": "__AZURE_FORM_RECOGNIZER_KEY__"
            },
            {
              "name": "OPENAI_API_KEY",
              "value": "__OPENAI_API_KEY__"
            },
            {
              "name": "OPENAI_API_BASE",
              "value": "__OPENAI_API_BASE__"
            },
            {
              "name": "OPENAI_DEPLOYMENT_NAME",
              "value": "__OPENAI_DEPLOYMENT_NAME__"
            }
          ],
          "volumeMounts": [
            {
              "name": "app-data",
              "mountPath": "/app/uploads"
            },
            {
              "name": "app-db",
              "mountPath": "/app"
            }
          ]
        }
      }
    ],
    "osType": "Linux",
    "ipAddress": {
      "type": "Public",
      "ports": [
        {
          "protocol": "tcp",
          "port": 80
        }
      ],
      "dnsNameLabel": "__DNS_LABEL__"
    },
    "volumes": [
      {
        "name": "app-data",
        "azureFile": {
          "shareName": "app-uploads",
          "storageAccountName": "__STORAGE_ACCOUNT__",
          "storageAccountKey": "__STORAGE_KEY__"
        }
      },
      {
        "name": "app-db",
        "emptyDir": {}
      }
    ],
    "restartPolicy": "OnFailure"
  }
}
