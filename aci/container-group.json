{
  "location": "eastus",
  "properties": {
    "imageRegistryCredentials": [
      {
        "server": "selamnew.azurecr.io",
        "username": "__ACR_USERNAME__",
        "password": "__ACR_PASSWORD__"
      }
    ],
    "containers": [
      {
        "name": "document-intelligence-app",
        "properties": {
          "image": "__IMAGE__",
          "resources": {
            "requests": {
              "cpu": 1,
              "memoryInGb": 2
            }
          },
          "ports": [
            {
              "port": 8000
            }
          ],
          "environmentVariables": [
            {
              "name": "SECRET_KEY",
              "secureValue": "__SECRET_KEY__"
            },
            {
              "name": "DATABASE_URL",
              "value": "sqlite:///./app.db"
            },
            {
              "name": "UPLOADS_DIR",
              "value": "uploads"
            },
            {
              "name": "AZURE_FORM_RECOGNIZER_ENDPOINT",
              "value": "__AZURE_FORM_RECOGNIZER_ENDPOINT__"
            },
            {
              "name": "AZURE_FORM_RECOGNIZER_KEY",
              "secureValue": "__AZURE_FORM_RECOGNIZER_KEY__"
            },
            {
              "name": "AZURE_LANGUAGE_ENDPOINT",
              "value": "__AZURE_LANGUAGE_ENDPOINT__"
            },
            {
              "name": "AZURE_LANGUAGE_KEY",
              "secureValue": "__AZURE_LANGUAGE_KEY__"
            },
            {
              "name": "AZURE_QNA_PROJECT_NAME",
              "value": "LearnFAQ"
            },
            {
              "name": "AZURE_QNA_DEPLOYMENT_NAME",
              "value": "production"
            },
            {
              "name": "OPENAI_API_KEY",
              "secureValue": "__OPENAI_API_KEY__"
            },
            {
              "name": "OPENAI_API_BASE",
              "value": "__OPENAI_API_BASE__"
            },
            {
              "name": "OPENAI_DEPLOYMENT_NAME",
              "value": "__OPENAI_DEPLOYMENT_NAME__"
            },
            {
              "name": "OPENAI_API_VERSION",
              "value": "2024-02-15-preview"
            },
            {
              "name": "AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME",
              "value": "__AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME__"
            },
            {
              "name": "AZURE_AI_VISION_ENDPOINT",
              "value": "__AZURE_AI_VISION_ENDPOINT__"
            },
            {
              "name": "AZURE_AI_VISION_KEY",
              "secureValue": "__AZURE_AI_VISION_KEY__"
            },
            {
              "name": "AZURE_SEARCH_ENDPOINT",
              "value": "__AZURE_SEARCH_ENDPOINT__"
            },
            {
              "name": "AZURE_SEARCH_KEY",
              "secureValue": "__AZURE_SEARCH_KEY__"
            },
            {
              "name": "AZURE_SEARCH_INDEX_NAME",
              "value": "rag-content-index"
            }
          ],
          "volumeMounts": [
            {
              "name": "app-data",
              "mountPath": "/app/uploads"
            }
          ]
        }
      }
    ],
    "osType": "Linux",
    "ipAddress": {
      "type": "Public",
      "ports": [
        {
          "protocol": "tcp",
          "port": 8000
        }
      ],
      "dnsNameLabel": "__DNS_LABEL__"
    },
    "volumes": [
      {
        "name": "app-data",
        "azureFile": {
          "shareName": "__FILE_SHARE_NAME__",
          "storageAccountName": "__STORAGE_ACCOUNT__",
          "storageAccountKey": "__STORAGE_KEY__"
        }
      }
    ],
    "restartPolicy": "OnFailure"
  }
}