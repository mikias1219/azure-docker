{
  "location": "eastus",
  "properties": {
    "imageRegistryCredentials": [
      {
        "server": "selamnew.azurecr.io",
        "username": "__ACR_USERNAME__",
        "password": "__ACR_PASSWORD__"
      }
    ],
    "containers": [
      {
        "name": "document-intelligence-app",
        "properties": {
          "image": "__IMAGE__",
          "resources": {
            "requests": {
              "cpu": 1,
              "memoryInGb": 2
            }
          },
          "ports": [
            {
              "port": 8000
            }
          ],
          "livenessProbe": {
            "httpGet": {
              "path": "/health",
              "port": 8000,
              "scheme": "http"
            },
            "initialDelaySeconds": 20,
            "periodSeconds": 15,
            "failureThreshold": 3,
            "timeoutSeconds": 5
          }
        }
      }
    ],
    "osType": "Linux",
    "ipAddress": {
      "type": "Public",
      "ports": [
        {
          "protocol": "tcp",
          "port": 8000
        }
      ],
      "dnsNameLabel": "__DNS_LABEL__"
    },
    "restartPolicy": "OnFailure"
  }
}
