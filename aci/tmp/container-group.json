{
  "location": "eastus",
  "properties": {
    "containers": [
      {
        "name": "fastapi-app",
        "properties": {
          "image": "selamnew.azurecr.io/fastapi-sample:latest",
          "resources": {
            "requests": {
              "cpu": 1,
              "memoryInGb": 1.5
            }
          },
          "ports": [
            {
              "port": 80
            }
          ],
          "environmentVariables": [
            {
              "name": "DATABASE_URL",
              "value": "postgresql://postgres:postgrespw@localhost:5432/postgres"
            }
          ]
        }
      },
      {
        "name": "postgres",
        "properties": {
          "image": "selamnew.azurecr.io/postgres:15",
          "resources": {
            "requests": {
              "cpu": 0.5,
              "memoryInGb": 1
            }
          },
          "environmentVariables": [
            { "name": "POSTGRES_USER", "value": "postgres" },
            { "name": "POSTGRES_PASSWORD", "value": "postgrespw" },
            { "name": "POSTGRES_DB", "value": "postgres" }
          ],
          "volumeMounts": [
            {
              "name": "pgdata",
              "mountPath": "/var/lib/postgresql/data"
            }
          ]
        }
      }
    ],
    "osType": "Linux",
    "ipAddress": {
      "type": "Public",
      "ports": [
        {
          "protocol": "tcp",
          "port": 80
        }
      ]
    },
    "volumes": [
      {
        "name": "pgdata",
        "emptyDir": {}
      }
    ]
  }
}
